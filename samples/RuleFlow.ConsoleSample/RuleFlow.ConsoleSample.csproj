  <ItemGroup>
    <ProjectReference Include="..\..\src\RuleFlow.Abstractions\RuleFlow.Abstractions.csproj" />
    <ProjectReference Include="..\..\src\RuleFlow.Core\RuleFlow.Core.csproj" />
